{
  "manifest_version": 3,
  "name": "Open Copilot",
  "description": "Floating browser-side AI chat with current-page context and local Ollama routing.",
  "version": "0.1.1",
  "permissions": [
    "storage",
    "alarms",
    "identity",
    "notifications",
    "contextMenus",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "http://127.0.0.1:11434/*",
    "https://api.github.com/*",
    "https://api.line.me/*",
    "https://api.telegram.org/*",
    "https://commons.wikimedia.org/*",
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "Open Copilot",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png"
    }
  },
  "commands": {
    "open-in-page-copilot": {
      "suggested_key": {
        "default": "Alt+Shift+O",
        "mac": "Command+Shift+O"
      },
      "description": "Open Open Copilot on the current page"
    }
  },
  "options_page": "src/options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "src/vendor/pdfjs/pdf.mjs",
        "src/vendor/pdfjs/pdf.worker.mjs"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "src/content-script.js"
      ],
      "css": [
        "src/injected.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
