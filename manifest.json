{
  "manifest_version": 3,
  "name": "Edge AI Chat",
  "description": "Floating browser-side AI chat with current-page context and local Ollama routing.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:11434/*",
    "https://api.github.com/*",
    "https://commons.wikimedia.org/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "Edge AI Chat",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png"
    }
  },
  "options_page": "src/options.html",
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "src/content-script.js"
      ],
      "css": [
        "src/injected.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
